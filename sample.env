# ── Required — secrets & credentials ──────────────────────────────────
# setup.sh generates these automatically. To set manually, replace
# every CHANGE_ME with a strong random value (e.g. openssl rand -hex 32).

# n8n workflow automation
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME

# Open WebUI session signing key
WEBUI_SECRET_KEY=CHANGE_ME

# Auth server (Cerberus) JWT signing key
JWT_SECRET=CHANGE_ME

# Service-to-service token (dashboard → agent platform)
INTERNAL_API_KEY=CHANGE_ME

# Vaultwarden admin panel token (/admin)
VAULTWARDEN_ADMIN_TOKEN=CHANGE_ME

# ── Optional — safe defaults already set in docker-compose.yml ───────
# Uncomment and change only if you need to override.

# API_TOKEN=
# SEQ_API_KEY=
# SEQ_ADMIN_PASSWORD=admin
# PORT=8000
# VAULTWARDEN_SIGNUPS_ALLOWED=true

# Timezone (IANA format)
TIMEZONE=America/Chicago
