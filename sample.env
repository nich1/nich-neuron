# Pipeline & Jobs
N8N_USER=admin
N8N_PASSWORD=changeme

# Reduce telemetry / external calls
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false

# Chat UI
WEBUI_SECRET_KEY=your-secret-key-change-in-production

# Seq (structured logging) — UI at http://localhost:5380
SEQ_ADMIN_PASSWORD=admin
SEQ_API_KEY=

# Auth server
JWT_SECRET=change-me-to-a-random-string

# Internal service-to-service token (dashboard → agent platform)
INTERNAL_API_KEY=change-me-to-a-random-string

# Agent platform
API_TOKEN=
PORT=8000
QDRANT_URL=http://qdrant:6333
DB_PATH=data/memory.db
DEFAULT_MODEL=qwen2.5:7b
EMBEDDING_MODEL=nomic-embed-text

# Notifications (Ntfy) — UI at http://localhost:8090
NTFY_URL=http://ntfy:80

# Shared (n8n timezone; IANA e.g. America/Chicago)
TIMEZONE=America/Chicago
